---
interface Props {
  title: string;
  description: string;
  lang: 'ja' | 'en';
  page?: string;
}

const { title, description, lang, page = 'home' } = Astro.props;
const isEn = lang === 'en';
const basePath = isEn ? '/en' : '/ja';
const siteUrl = 'https://cybertrip.co.jp';
const ogImage = `${siteUrl}/og-image.png`;
const currentUrl = `${siteUrl}${Astro.url.pathname}`;
---

<!DOCTYPE html>
<html lang={lang}>
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{title}</title>
  <meta name="description" content={description}>

  <!-- OGP / Social -->
  <meta property="og:title" content={title}>
  <meta property="og:description" content={description}>
  <meta property="og:image" content={ogImage}>
  <meta property="og:url" content={currentUrl}>
  <meta property="og:type" content="website">
  <meta property="og:site_name" content="CyberTrip">
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content={title}>
  <meta name="twitter:description" content={description}>
  <meta name="twitter:image" content={ogImage}>

  <link rel="alternate" hreflang="ja" href={`https://cybertrip.co.jp/ja/`}>
  <link rel="alternate" hreflang="en" href={`https://cybertrip.co.jp/en/`}>

  <!-- Favicon / Touch Icons -->
  <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png">
  <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png">
  <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png">
  <link rel="manifest" href="/manifest.json">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
</head>
<body class:list={[{ en: isEn }, 'has-banner']} data-page={page}>
  <!-- Page Load Curtain -->
  <div class="page-curtain" id="pageCurtain">
    <img src="/icon.png" alt="" class="page-curtain-logo" width="48" height="48" />
  </div>

  <!-- Scroll Progress Bar -->
  <div class="scroll-progress" id="scrollProgress"></div>

  <!-- Cursor Glow -->
  <div class="cursor-glow" id="cursorGlow"></div>

  <slot />

  <script is:inline src="https://cdn.jsdelivr.net/npm/gsap@3/dist/gsap.min.js"></script>
  <script is:inline src="https://cdn.jsdelivr.net/npm/gsap@3/dist/ScrollTrigger.min.js"></script>
  <script is:inline src="https://unpkg.com/lenis@1/dist/lenis.min.js"></script>
  <script is:inline src="/scripts/main.js"></script>
  <script is:inline src="/scripts/premium-animations.js"></script>
</body>
</html>

<style is:global>
  @import '../styles/global.css';
  @import '../styles/premium-animations.css';
</style>
