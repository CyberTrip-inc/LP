---
interface Props {
  lang: 'ja' | 'en';
}

const { lang } = Astro.props;
const isEn = lang === 'en';

const images = [
  { src: '/images/philosophy-1.webp', alt: isEn ? 'Friends on a mountain at sunset' : '夕日の山頂で肩を組む仲間' },
  { src: '/images/philosophy-2.webp', alt: isEn ? 'Travelers sharing a moment' : '旅先で語り合うトラベラー' },
  { src: '/images/philosophy-3.webp', alt: isEn ? 'Encounter at the summit' : '山頂での出会い' },
  { src: '/images/philosophy-4.webp', alt: isEn ? 'Two pairs of feet at the edge' : '崖の先に並ぶ二人の足' },
];
---

<div class="image-row">
  {images.map((img) => (
    <div class="img-cell">
      <img src={img.src} alt={img.alt} loading="lazy" />
    </div>
  ))}
</div>
