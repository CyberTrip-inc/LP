---
interface Props {
  lang: 'ja' | 'en';
}

const { lang } = Astro.props;
const isEn = lang === 'en';
const base = isEn ? '/en' : '/ja';
---

<footer class="footer">
  <div class="footer-inner">
    <div>
      <a href={`${base}/`} class="footer-logo">
        <span class="logo-mark"><img src="/icon.png" alt="" width="28" height="28" /></span>
        CyberTrip
      </a>
      <div class="footer-company-info">
        {isEn ? 'CyberTrip, Inc.' : '株式会社CyberTrip'}
      </div>
    </div>
    <div class="footer-links">
      <div class="footer-links-col">
        <a href={`${base}/philosophy/`}>Philosophy</a>
        <a href={`${base}/drift/`}>Drift</a>
      </div>
      <div class="footer-links-col">
        <a href={`${base}/company/`}>Company</a>
      </div>
    </div>
  </div>
  <div class="footer-bottom">
    <span class="footer-copy">&copy; 2025 CyberTrip, Inc. All rights reserved.</span>
    <div class="footer-bottom-right">
      <div class="footer-lang">
        <a href="/ja/" class:list={[{ active: !isEn }]}>JP</a>
        <a href="/en/" class:list={[{ active: isEn }]}>EN</a>
      </div>
    </div>
  </div>
</footer>
