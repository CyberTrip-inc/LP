---
interface Props {
  lang: 'ja' | 'en';
}

const { lang } = Astro.props;
const isEn = lang === 'en';
---

<section class="closing">
  <div class="closing-aurora">
    <div class="closing-blob closing-blob--1"></div>
    <div class="closing-blob closing-blob--2"></div>
  </div>
  <p class="closing-text text-highlight-scroll">
    {isEn
      ? 'The moment you close this page and look up, your CyberTrip begins.'
      : 'このページを閉じ、顔を上げた瞬間に、あなたのCyberTripは始まります。'}
  </p>
</section>
