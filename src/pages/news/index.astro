---
import Base from '../../layouts/Base.astro';
import Header from '../../components/Header.astro';
import AnnounceBanner from '../../components/AnnounceBanner.astro';
import Footer from '../../components/Footer.astro';
import { getCollection } from 'astro:content';

const lang = 'ja';

const allNews = await getCollection('news');
const sorted = allNews.sort((a, b) => b.data.date.localeCompare(a.data.date));

const newsItems = sorted.filter(n => n.data.category !== 'notice');
---

<Base
  title="お知らせ — CyberTrip"
  description="株式会社CyberTripからのお知らせ一覧。"
  lang={lang}
  page="news"
>
  <AnnounceBanner lang={lang} />
  <Header lang={lang} page="news" />

  <section class="page-hero page-hero--news">
    <div class="page-hero-inner">
      <p class="page-hero-label">News</p>
      <h1 class="page-hero-title">お知らせ</h1>
      <p class="page-hero-sub">
        株式会社CyberTripからのお知らせを掲載しています。
      </p>
    </div>
  </section>

  <section class="section section--dark">
    <div class="section-inner">
      <div class="section-label-line">
        <span class="section-label">お知らせ</span>
      </div>
      {newsItems.length > 0 ? (
        <div class="news-list">
          {newsItems.map((item) => {
            const title = item.data.title;
            const badge = item.data.badge;
            const linkHref = item.data.link ? `/ja${item.data.link}` : undefined;
            const linkText = item.data.link_text;
            return (
              <div class="news-item">
                <div class="news-item-date">{item.data.date}</div>
                <div class="news-item-content">
                  {badge && <span class="news-item-badge">{badge}</span>}
                  <span class="news-item-title">{title}</span>
                  {linkHref && linkText && (
                    <a href={linkHref} class="news-item-link">{linkText} &rarr;</a>
                  )}
                </div>
              </div>
            );
          })}
        </div>
      ) : (
        <p class="news-empty">現在、お知らせはありません。</p>
      )}
    </div>
  </section>

  <Footer lang={lang} />
</Base>
