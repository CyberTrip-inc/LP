---
import Base from '../../layouts/Base.astro';
import Header from '../../components/Header.astro';
import AnnounceBanner from '../../components/AnnounceBanner.astro';
import Forge from '../../components/Forge.astro';
import Footer from '../../components/Footer.astro';

const lang = 'ja';
---

<Base
  title="Forge — CyberTrip"
  description="食事 × 筋トレ × 体の変化をAIが統合分析し、理想のカラダまでの最短ルートを描くAIフィットネス・栄養管理アプリ Forge。"
  lang={lang}
  page="forge"
>
  <AnnounceBanner lang={lang} />
  <Header lang={lang} page="forge" />

  <!-- Forge Hero -->
  <section class="drift-hero">
    <div class="drift-hero-aurora">
      <div class="drift-hero-blob drift-hero-blob--1"></div>
      <div class="drift-hero-blob drift-hero-blob--2"></div>
    </div>
    <div class="drift-hero-inner">
      <p class="page-hero-label">Product</p>
      <h1 class="drift-hero-name text-shimmer">FORGE</h1>
      <p class="drift-hero-tagline">理想のカラダを、最短で。</p>
      <p class="drift-hero-desc">
        食事 × 筋トレ × 体の変化を、AIが統合分析。<br />
        我慢でも、根性でもない。<br />
        テクノロジーで「最短ルート」を描く、AIフィットネス・栄養管理アプリ。
      </p>
    </div>
  </section>

  <!-- Concept -->
  <section class="section section--dark">
    <div class="section-inner">
      <div class="section-label-line">
        <span class="section-label">Concept</span>
      </div>
      <div class="drift-concept">
        <div class="drift-concept-main">
          <h2 class="drift-concept-heading fade-up">
            ダラダラ続ける健康アプリは、<br />もういらない。
          </h2>
          <p class="drift-concept-body fade-up">
            ほとんどの食事・フィットネス系アプリは、「記録すること」自体を目的にしてしまっている。続けるほど、データは溜まるが、体は変わらない。Forgeが目指すのは逆方向だ——<strong>理想のカラダに、最短で辿り着く</strong>こと。
          </p>
          <p class="drift-concept-body fade-up">
            食事は摂取の最適化。筋トレは消費とトレーニングの最適化。体重と写真は進捗の検証。それらをAIが横断して分析し、「次に何をすべきか」を毎日提示する。<br />
            判断基準はひとつ。<strong>これは理想のカラダへの最短ルートに貢献するか？</strong>
          </p>
        </div>
        <div class="drift-concept-side">
          <div class="drift-concept-quote fade-up">
            <span class="drift-concept-quote-mark">"</span>
            <p>続けることが目的ではない。<br />最短で、変わるためのアプリ。</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- How it works -->
  <section class="section section--darker">
    <div class="section-inner">
      <div class="section-label-line">
        <span class="section-label">How It Works</span>
      </div>
      <div class="drift-flow">
        <div class="drift-flow-step fade-up">
          <div class="drift-flow-number drift-flow-number--accent">01</div>
          <h3 class="drift-flow-title">写真を撮る</h3>
          <p class="drift-flow-body">食事をカメラで撮るだけ。手・スマホ・箸を基準にAIが分量を推定。隠れた油や砂糖まで推定する。</p>
        </div>
        <div class="drift-flow-step fade-up">
          <div class="drift-flow-number drift-flow-number--teal">02</div>
          <h3 class="drift-flow-title">トレーニングと体重を記録</h3>
          <p class="drift-flow-body">筋トレのセット・レップ、体重・体脂肪を素早く入力。3秒で習慣化できる設計。</p>
        </div>
        <div class="drift-flow-step fade-up">
          <div class="drift-flow-number drift-flow-number--blue">03</div>
          <h3 class="drift-flow-title">AIが統合分析する</h3>
          <p class="drift-flow-body">食事・運動・体の変化を横断分析。「今日の選択が目標にどう効くか」を毎朝、毎晩教える。</p>
        </div>
        <div class="drift-flow-step fade-up">
          <div class="drift-flow-number drift-flow-number--accent">04</div>
          <h3 class="drift-flow-title">最短で結果が出る</h3>
          <p class="drift-flow-body">数値とボディ写真の比較で進捗を確認。理想のカラダまでの距離が、毎日縮む。</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Features (Bento Grid) -->
  <Forge lang={lang} />

  <!-- Why Forge -->
  <section class="section section--darker">
    <div class="section-inner">
      <div class="section-label-line">
        <span class="section-label">Why Forge</span>
      </div>
      <h2 class="drift-concept-heading fade-up" style="margin-bottom:2.5rem;">
        なぜ、既存のアプリでは続かないのか。
      </h2>
      <div class="why-drift-grid">
        <div class="why-drift-card fade-up">
          <div class="why-drift-icon">&#x2715;</div>
          <h3 class="why-drift-title">栄養管理アプリ</h3>
          <p class="why-drift-body">入力が手動で重い。続かないし、運動とも切り離されている。データは溜まるが、結果は出ない。</p>
        </div>
        <div class="why-drift-card fade-up">
          <div class="why-drift-icon">&#x2715;</div>
          <h3 class="why-drift-title">フィットネスアプリ</h3>
          <p class="why-drift-body">運動の記録だけ。食事も体の変化も、別アプリ任せ。「何が効いたか」を判定できない。</p>
        </div>
        <div class="why-drift-card why-drift-card--accent why-drift-card--drift fade-up">
          <div class="why-drift-icon">&#x2713;</div>
          <h3 class="why-drift-title">Forge</h3>
          <p class="why-drift-body">食事・運動・体の変化をAIが統合し、ひとつの最短ルートに変換する。判断はすべて「最短で変わる」基準。続けるためではなく、変わるためのアプリ。</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Target Users -->
  <section class="section section--dark">
    <div class="section-inner">
      <div class="section-label-line">
        <span class="section-label">Who It's For</span>
      </div>
      <h2 class="drift-concept-heading fade-up" style="margin-bottom:2.5rem;">
        Forgeが最初に届く人たち。
      </h2>
      <div class="target-grid">
        <div class="target-card fade-up">
          <div class="target-emoji">&#x1F525;</div>
          <h3 class="target-title">自己流ダイエットで停滞している人</h3>
          <p class="target-body">食事制限と運動を頑張っているのに、結果が出ない。何が足りないのかが、自分ではわからない層。</p>
        </div>
        <div class="target-card fade-up">
          <div class="target-emoji">&#x1F4AA;</div>
          <h3 class="target-title">パーソナル卒業後の継続層</h3>
          <p class="target-body">パーソナルトレーニングで結果は出たが、卒業後に1人で続けられるか不安な人。AIが「次の一手」を提示することで、自走できる。</p>
        </div>
        <div class="target-card fade-up">
          <div class="target-emoji">&#x1F3AF;</div>
          <h3 class="target-title">最短主義のビジネスパーソン</h3>
          <p class="target-body">時間は有限。ストイックさで殴るのではなく、テクノロジーで「最短ルート」を選びたい20-30代。</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Roadmap -->
  <section class="section section--darker">
    <div class="section-inner">
      <div class="section-label-line">
        <span class="section-label">Roadmap</span>
      </div>
      <h2 class="drift-concept-heading fade-up" style="margin-bottom:2.5rem;">
        ここから、始まる。
      </h2>
      <div class="roadmap">
        <div class="roadmap-item roadmap-item--active fade-up">
          <div class="roadmap-dot"></div>
          <div class="roadmap-content">
            <div class="roadmap-date">2026 Q1</div>
            <h3 class="roadmap-title">コンセプト設計・MVP開発</h3>
            <p class="roadmap-body">「理想のカラダを最短で」を判断基準に、コア機能を絞り込み。AI食事解析と統合分析エンジンの開発を開始。</p>
          </div>
        </div>
        <div class="roadmap-item fade-up">
          <div class="roadmap-dot"></div>
          <div class="roadmap-content">
            <div class="roadmap-date">2026 Q2</div>
            <h3 class="roadmap-title">クローズドβ提供</h3>
            <p class="roadmap-body">10-30名規模のユーザーで実機検証。AI解析精度・継続率・体組成変化を測定し、最短ルートの定義を磨く。</p>
          </div>
        </div>
        <div class="roadmap-item fade-up">
          <div class="roadmap-dot"></div>
          <div class="roadmap-content">
            <div class="roadmap-date">2026 Q3</div>
            <h3 class="roadmap-title">パブリックβ・iOSリリース</h3>
            <p class="roadmap-body">App Storeへ公開。日本国内のフィットネス層を起点に拡大。AI事前チェックとボディ写真比較を搭載。</p>
          </div>
        </div>
        <div class="roadmap-item fade-up">
          <div class="roadmap-dot"></div>
          <div class="roadmap-content">
            <div class="roadmap-date">2026 Q4</div>
            <h3 class="roadmap-title">AIコーチング機能</h3>
            <p class="roadmap-body">ユーザーごとの履歴に基づくパーソナル提案を強化。トレーニング種目・栄養素・休養までをAIが統合的に処方する。</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section section--dark drift-cta-section">
    <div class="section-inner" style="text-align:center;">
      <h2 class="drift-cta-heading fade-up">理想のカラダまで、<br />最短で連れていく。</h2>
      <p class="section-body fade-up" style="margin:1.5rem auto 2.5rem;text-align:center;">
        Forgeは現在開発中です。最新情報をお届けします。
      </p>
      <a href="mailto:cybertrip.inc@gmail.com" class="btn-pill btn-pill--accent magnetic-btn fade-up">
        <span class="magnetic-btn-text">お問い合わせ <span class="arrow">&rarr;</span></span>
      </a>
    </div>
  </section>

  <!-- Sticky CTA -->
  <div class="sticky-cta" id="stickyCta">
    <span class="sticky-cta-text">Forgeは現在開発中</span>
    <a href="mailto:cybertrip.inc@gmail.com" class="sticky-cta-btn">お問い合わせ <span class="arrow">&rarr;</span></a>
  </div>

  <Footer lang={lang} />
</Base>

<script>
  const stickyCta = document.getElementById('stickyCta');
  const hero = document.querySelector('.drift-hero');
  const footer = document.querySelector('footer');
  if (stickyCta && hero && footer) {
    const observer = new IntersectionObserver(([entry]) => {
      stickyCta.classList.toggle('sticky-cta--visible', !entry.isIntersecting);
    }, { threshold: 0 });
    observer.observe(hero);
    const footerObs = new IntersectionObserver(([entry]) => {
      stickyCta.classList.toggle('sticky-cta--hidden', entry.isIntersecting);
    }, { threshold: 0 });
    footerObs.observe(footer);
  }
</script>
