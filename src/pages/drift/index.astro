---
import Base from '../../layouts/Base.astro';
import Header from '../../components/Header.astro';
import AnnounceBanner from '../../components/AnnounceBanner.astro';
import Drift from '../../components/Drift.astro';
import WhyTravel from '../../components/WhyTravel.astro';
import Footer from '../../components/Footer.astro';

const lang = 'ja';
---

<Base
  title="Drift — CyberTrip"
  description="計画しない旅の中で、自然に人と出会う。漂流するように、偶然を楽しむための旅行アプリ Drift。"
  lang={lang}
  page="drift"
>
  <AnnounceBanner lang={lang} />
  <Header lang={lang} page="drift" />

  <!-- Drift Hero -->
  <section class="drift-hero">
    <div class="drift-hero-aurora">
      <div class="drift-hero-blob drift-hero-blob--1"></div>
      <div class="drift-hero-blob drift-hero-blob--2"></div>
    </div>
    <div class="drift-hero-inner">
      <p class="page-hero-label">Product</p>
      <h1 class="drift-hero-name text-shimmer">DRIFT</h1>
      <p class="drift-hero-tagline">漂流するように、出会う。</p>
      <p class="drift-hero-desc">
        計画された旅では出会えない人がいる。<br />
        Driftは「偶然」を設計する旅行アプリ。<br />
        漂流のように自然に人と交わる場所を、テクノロジーでつくる。
      </p>
    </div>
  </section>

  <!-- App Preview -->
  <section class="section section--darker">
    <div class="section-inner">
      <div class="section-label-line">
        <span class="section-label">App Preview</span>
      </div>
      <h2 class="drift-concept-heading fade-up" style="text-align:center;margin-bottom:1rem;">
        旅の出会いを、一つのアプリに。
      </h2>
      <p class="drift-concept-body fade-up" style="text-align:center;margin-bottom:3rem;">
        旅の登録からすれ違い、再会まで。すべてのフェーズをDriftが一貫して支える。
      </p>
      <div class="app-preview-screens">
        <div class="app-preview-item fade-up">
          <div class="app-preview-phone">
            <img src="/images/preview/app1.webp" alt="My Trips — 旅を登録し、同じ方向に向かう人を見つける" loading="lazy" />
          </div>
          <h3 class="app-preview-label">My Trips</h3>
          <p class="app-preview-desc">旅を登録。同じ場所・同じ時期に向かう人が見つかる。</p>
        </div>
        <div class="app-preview-item fade-up">
          <div class="app-preview-phone">
            <img src="/images/preview/app2.webp" alt="Live Map — 近くにいるトラベラーをリアルタイムで表示" loading="lazy" />
          </div>
          <h3 class="app-preview-label">Live Map</h3>
          <p class="app-preview-desc">今、近くにいるトラベラーが見える。すれ違いを逃さない。</p>
        </div>
        <div class="app-preview-item fade-up">
          <div class="app-preview-phone">
            <img src="/images/preview/app3.webp" alt="AI Concierge — やりたいことを伝えるだけで人も場所も見つかる" loading="lazy" />
          </div>
          <h3 class="app-preview-label">AI Concierge</h3>
          <p class="app-preview-desc">やりたいことを伝えるだけ。人も場所も、AIが見つける。</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Concept -->
  <section class="section section--dark">
    <div class="section-inner">
      <div class="section-label-line">
        <span class="section-label">Concept</span>
      </div>
      <div class="drift-concept">
        <div class="drift-concept-main">
          <h2 class="drift-concept-heading fade-up">
            予定にない出会いが、<br />人生を変えることがある。
          </h2>
          <p class="drift-concept-body fade-up">
            Drift——漂流。決められた計画の中ではなく、自然発生的に起きる流れの中で人と出会う。旅先での偶然の会話、同じ宿に居合わせた夜、目的地が重なった見知らぬ誰か。そういう瞬間こそが、記憶に残り、人を変える。
          </p>
          <p class="drift-concept-body fade-up">
            Driftは「出会いの量」を追わない。<br />
            出会いが「意味を持ったか」を測り、蓄積する。旅前のつながりから、旅中のすれ違い、旅後の関係継続まで。すべてのフェーズで、偶然を逃さず、本物の出会いを検証する。
          </p>
        </div>
        <div class="drift-concept-side">
          <div class="drift-concept-quote fade-up">
            <span class="drift-concept-quote-mark">"</span>
            <p>人を探しに行くのではない。<br />やりたいことの先に、<br />人がいる。</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- How it works -->
  <section class="section section--darker">
    <div class="section-inner">
      <div class="section-label-line">
        <span class="section-label">How It Works</span>
      </div>
      <div class="drift-flow">
        <div class="drift-flow-step fade-up">
          <div class="drift-flow-number drift-flow-number--accent">01</div>
          <h3 class="drift-flow-title">旅を登録する</h3>
          <p class="drift-flow-body">期間と行き先を入力。ソロでもグループでも。Driftが同じ場所・時期に向かう人を自動で見つける。</p>
        </div>
        <div class="drift-flow-step fade-up">
          <div class="drift-flow-number drift-flow-number--teal">02</div>
          <h3 class="drift-flow-title">旅前につながる</h3>
          <p class="drift-flow-body">目的が合う人にConnect申請。出発前に会話が始まる。旅の期待値が、すでにここで変わる。</p>
        </div>
        <div class="drift-flow-step fade-up">
          <div class="drift-flow-number drift-flow-number--blue">03</div>
          <h3 class="drift-flow-title">現地ですれ違う</h3>
          <p class="drift-flow-body">Live Mapとすれ違い通知が偶然を可視化。計画外の出会いも、Driftが拾い上げる。</p>
        </div>
        <div class="drift-flow-step fade-up">
          <div class="drift-flow-number drift-flow-number--accent">04</div>
          <h3 class="drift-flow-title">関係が旅を超えて残る</h3>
          <p class="drift-flow-body">旅が終わっても、つながりは消えない。次の旅で再会したとき、Driftはその関係が本物だったことを証明する。</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Features (Bento Grid) -->
  <Drift lang={lang} />

  <!-- Why Travel -->
  <WhyTravel lang={lang} />

  <!-- Why Now -->
  <section class="section section--dark">
    <div class="section-inner">
      <div class="section-label-line">
        <span class="section-label">Why Now</span>
      </div>
      <div class="home-stats">
        <div class="home-stat fade-up">
          <div class="home-stat-number counter-glow"><span class="counter" data-target="71">0</span><span class="home-stat-unit">%</span></div>
          <div class="home-stat-label">旅先で出会いを積極的に求めているソロトラベラーの割合<span class="stat-source">*</span></div>
        </div>
        <div class="home-stat fade-up">
          <div class="home-stat-number counter-glow"><span class="counter" data-target="52">0</span><span class="home-stat-unit">%</span></div>
          <div class="home-stat-label">旅で出会った人と継続的に連絡を取り合うソロトラベラーの割合<span class="stat-source">*</span></div>
        </div>
        <div class="home-stat fade-up">
          <div class="home-stat-number counter-glow"><span class="counter" data-target="0">0</span><span class="home-stat-unit">個</span></div>
          <div class="home-stat-label">「出会いの質」を測定する<br />旅行アプリは、まだない</div>
        </div>
      </div>
      <p class="stat-footnote fade-up">* 出典: Hostelworld「State of Solo Travel Report 2025」— 世界のソロトラベラー3,334人を対象とした調査</p>
    </div>
  </section>

  <!-- Why Drift -->
  <section class="section section--darker">
    <div class="section-inner">
      <div class="section-label-line">
        <span class="section-label">Why Drift</span>
      </div>
      <h2 class="drift-concept-heading fade-up" style="margin-bottom:2.5rem;">
        なぜ、既存のアプリではだめなのか。
      </h2>
      <div class="why-drift-grid">
        <div class="why-drift-card fade-up">
          <div class="why-drift-icon">&#x2715;</div>
          <h3 class="why-drift-title">マッチングアプリ</h3>
          <p class="why-drift-body">目的が「人を探すこと」自体。プロフィールで選別し、会話は目的ありき。旅先の偶然性はゼロ。</p>
        </div>
        <div class="why-drift-card fade-up">
          <div class="why-drift-icon">&#x2715;</div>
          <h3 class="why-drift-title">旅行SNS / 掲示板</h3>
          <p class="why-drift-body">情報共有が主目的。「同じ場所に同時にいる」ことを活かす仕組みがなく、出会いはオフラインの偶然任せ。</p>
        </div>
        <div class="why-drift-card why-drift-card--accent why-drift-card--drift fade-up">
          <div class="why-drift-icon">&#x2713;</div>
          <h3 class="why-drift-title">Drift</h3>
          <p class="why-drift-body">旅の行動を起点に、同じ場所・同じ時間にいる人と自然につながる。出会いの「量」ではなく「意味」を測定し蓄積する、唯一のアプリ。</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Target Users -->
  <section class="section section--dark">
    <div class="section-inner">
      <div class="section-label-line">
        <span class="section-label">Who It's For</span>
      </div>
      <h2 class="drift-concept-heading fade-up" style="margin-bottom:2.5rem;">
        Driftが最初に届く人たち。
      </h2>
      <div class="target-grid">
        <div class="target-card fade-up">
          <div class="target-emoji">&#x1F30F;</div>
          <h3 class="target-title">20〜30代のソロトラベラー</h3>
          <p class="target-body">旅先でのリアルな出会いに価値を感じているが、きっかけがない。偶然に期待しつつも、アプリで「マッチング」したくはない層。</p>
        </div>
        <div class="target-card fade-up">
          <div class="target-emoji">&#x1F3D5;</div>
          <h3 class="target-title">ワーケーション・長期滞在者</h3>
          <p class="target-body">1〜3ヶ月の滞在中に現地コミュニティとつながりたい。仕事仲間ではない、旅先ならではの関係を求めている。</p>
        </div>
        <div class="target-card fade-up">
          <div class="target-emoji">&#x1F91D;</div>
          <h3 class="target-title">グループ旅行のオーガナイザー</h3>
          <p class="target-body">旅行サークル、社会人グループなど、メンバー同士のつながりを深めたい人。Driftが旅の体験を構造化し、再訪率を上げる。</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Roadmap -->
  <section class="section section--darker">
    <div class="section-inner">
      <div class="section-label-line">
        <span class="section-label">Roadmap</span>
      </div>
      <h2 class="drift-concept-heading fade-up" style="margin-bottom:2.5rem;">
        ここから、始まる。
      </h2>
      <div class="roadmap">
        <div class="roadmap-item roadmap-item--active fade-up">
          <div class="roadmap-dot"></div>
          <div class="roadmap-content">
            <div class="roadmap-date">2026 Q1</div>
            <h3 class="roadmap-title">創業・プロダクト設計</h3>
            <p class="roadmap-body">会社設立。コアコンセプト設計、MVP仕様策定。</p>
          </div>
        </div>
        <div class="roadmap-item fade-up">
          <div class="roadmap-dot"></div>
          <div class="roadmap-content">
            <div class="roadmap-date">2026 Q2</div>
            <h3 class="roadmap-title">パブリックβ提供開始</h3>
            <p class="roadmap-body">一般ユーザーへβ版を公開。東南アジアのバックパッカー聖地（バリ島・バンコク）を起点に検証。</p>
          </div>
        </div>
        <div class="roadmap-item fade-up">
          <div class="roadmap-dot"></div>
          <div class="roadmap-content">
            <div class="roadmap-date">2026 Q3</div>
            <h3 class="roadmap-title">正式リリース・グローバル展開</h3>
            <p class="roadmap-body">App Store / Google Play公開。英語圏・東南アジアを中心にグローバル展開。AIコンシェルジュ搭載。</p>
          </div>
        </div>
        <div class="roadmap-item fade-up">
          <div class="roadmap-dot"></div>
          <div class="roadmap-content">
            <div class="roadmap-date">2026 Q4</div>
            <h3 class="roadmap-title">Drift for Business</h3>
            <p class="roadmap-body">旅行会社・ホステル・観光自治体向けのB2Bプラン提供開始。エンカウンターデータを活用した集客支援・観光施策の最適化を実現。</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section section--dark drift-cta-section">
    <div class="section-inner" style="text-align:center;">
      <h2 class="drift-cta-heading fade-up">漂流の先で、<br />誰かと出会う旅を。</h2>
      <p class="section-body fade-up" style="margin:1.5rem auto 2.5rem;text-align:center;">
        Driftは現在開発中です。最新情報をお届けします。
      </p>
      <a href="mailto:cybertrip.inc@gmail.com" class="btn-pill btn-pill--accent magnetic-btn fade-up">
        <span class="magnetic-btn-text">お問い合わせ <span class="arrow">&rarr;</span></span>
      </a>
    </div>
  </section>

  <!-- Sticky CTA -->
  <div class="sticky-cta" id="stickyCta">
    <span class="sticky-cta-text">Driftは現在開発中</span>
    <a href="mailto:cybertrip.inc@gmail.com" class="sticky-cta-btn">お問い合わせ <span class="arrow">&rarr;</span></a>
  </div>

  <Footer lang={lang} />
</Base>

<script>
  const stickyCta = document.getElementById('stickyCta');
  const hero = document.querySelector('.drift-hero');
  const footer = document.querySelector('footer');
  if (stickyCta && hero && footer) {
    const observer = new IntersectionObserver(([entry]) => {
      stickyCta.classList.toggle('sticky-cta--visible', !entry.isIntersecting);
    }, { threshold: 0 });
    observer.observe(hero);
    const footerObs = new IntersectionObserver(([entry]) => {
      stickyCta.classList.toggle('sticky-cta--hidden', entry.isIntersecting);
    }, { threshold: 0 });
    footerObs.observe(footer);
  }
</script>
