---
import Base from '../../../layouts/Base.astro';
import Header from '../../../components/Header.astro';
import AnnounceBanner from '../../../components/AnnounceBanner.astro';
import Drift from '../../../components/Drift.astro';
import WhyTravel from '../../../components/WhyTravel.astro';
import Footer from '../../../components/Footer.astro';

const lang = 'en';
---

<Base
  title="Drift — CyberTrip"
  description="The travel app where unplanned encounters become lasting connections. Drift designs serendipity."
  lang={lang}
  page="drift"
>
  <AnnounceBanner lang={lang} />
  <Header lang={lang} page="drift" />

  <!-- Drift Hero -->
  <section class="drift-hero">
    <div class="drift-hero-aurora">
      <div class="drift-hero-blob drift-hero-blob--1"></div>
      <div class="drift-hero-blob drift-hero-blob--2"></div>
    </div>
    <div class="drift-hero-inner">
      <p class="page-hero-label">Product</p>
      <h1 class="drift-hero-name">DRIFT</h1>
      <p class="drift-hero-tagline">Meet people like<br />the ocean finds the shore.</p>
      <p class="drift-hero-desc">
        The best encounters aren't planned — they emerge.<br />
        Drift is a travel app that designs serendipity.<br />
        Where currents of travel carry people together, naturally.
      </p>
    </div>
  </section>

  <!-- App Preview -->
  <section class="section section--darker">
    <div class="section-inner">
      <div class="section-label-line">
        <span class="section-label">App Preview</span>
      </div>
      <h2 class="drift-concept-heading fade-up" style="text-align:center;margin-bottom:1rem;">
        Every encounter, in one app.
      </h2>
      <p class="drift-concept-body fade-up" style="text-align:center;margin-bottom:3rem;">
        From trip registration to chance encounters to reunions. Drift supports every phase.
      </p>
      <div class="app-preview-screens">
        <div class="app-preview-item fade-up">
          <div class="app-preview-phone">
            <img src="/images/preview/app1.webp" alt="My Trips — Register trips and find travelers heading the same way" loading="lazy" />
          </div>
          <h3 class="app-preview-label">My Trips</h3>
          <p class="app-preview-desc">Register a trip. Find people heading to the same place, same time.</p>
        </div>
        <div class="app-preview-item fade-up">
          <div class="app-preview-phone">
            <img src="/images/preview/app2.webp" alt="Live Map — See nearby travelers in real time" loading="lazy" />
          </div>
          <h3 class="app-preview-label">Live Map</h3>
          <p class="app-preview-desc">See who's around you, right now. Never miss a chance encounter.</p>
        </div>
        <div class="app-preview-item fade-up">
          <div class="app-preview-phone">
            <img src="/images/preview/app3.webp" alt="AI Concierge — Tell it what you want, it finds who and where" loading="lazy" />
          </div>
          <h3 class="app-preview-label">AI Concierge</h3>
          <p class="app-preview-desc">Tell it what you want. It finds people and places for you.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Concept -->
  <section class="section section--dark">
    <div class="section-inner">
      <div class="section-label-line">
        <span class="section-label">Concept</span>
      </div>
      <div class="drift-concept">
        <div class="drift-concept-main">
          <h2 class="drift-concept-heading fade-up">
            Unplanned encounters<br />change lives.
          </h2>
          <p class="drift-concept-body fade-up">
            Drift — to move without a fixed course. Not matching algorithms, not curated profiles. The conversation that happens by chance at a hostel. The stranger heading to the same place. The moments that stay with you long after the trip ends.
          </p>
          <p class="drift-concept-body fade-up">
            Drift doesn't chase volume.<br />
            It measures whether encounters actually mattered — and accumulates them. From pre-trip connections to real-time proximity, to relationships that outlast the journey. Every phase, every chance, verified.
          </p>
        </div>
        <div class="drift-concept-side">
          <div class="drift-concept-quote fade-up">
            <span class="drift-concept-quote-mark">"</span>
            <p>You don't search for people.<br />You follow what you want to do —<br />and people are there.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- How it works -->
  <section class="section section--darker">
    <div class="section-inner">
      <div class="section-label-line">
        <span class="section-label">How It Works</span>
      </div>
      <div class="drift-flow">
        <div class="drift-flow-step fade-up">
          <div class="drift-flow-number drift-flow-number--accent">01</div>
          <h3 class="drift-flow-title">Register a trip</h3>
          <p class="drift-flow-body">Enter your dates and destination. Solo or group. Drift automatically finds people heading the same way at the same time.</p>
        </div>
        <div class="drift-flow-step fade-up">
          <div class="drift-flow-number drift-flow-number--teal">02</div>
          <h3 class="drift-flow-title">Connect before you go</h3>
          <p class="drift-flow-body">Send Connect requests to people with aligned interests. Conversations begin before departure. The trip already feels different.</p>
        </div>
        <div class="drift-flow-step fade-up">
          <div class="drift-flow-number drift-flow-number--blue">03</div>
          <h3 class="drift-flow-title">Cross paths on-site</h3>
          <p class="drift-flow-body">Live Map and proximity alerts make the invisible visible. Even unplanned encounters get captured by Drift.</p>
        </div>
        <div class="drift-flow-step fade-up">
          <div class="drift-flow-number drift-flow-number--accent">04</div>
          <h3 class="drift-flow-title">Relationships outlast the trip</h3>
          <p class="drift-flow-body">Connections don't expire. When you meet again on a future trip, Drift proves the relationship was real.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Features (Bento Grid) -->
  <Drift lang={lang} />

  <!-- Why Travel -->
  <WhyTravel lang={lang} />

  <!-- Why Drift -->
  <section class="section section--darker">
    <div class="section-inner">
      <div class="section-label-line">
        <span class="section-label">Why Drift</span>
      </div>
      <h2 class="drift-concept-heading fade-up" style="margin-bottom:2.5rem;">
        Why existing apps fall short.
      </h2>
      <div class="why-drift-grid">
        <div class="why-drift-card fade-up">
          <div class="why-drift-icon">&#x2715;</div>
          <h3 class="why-drift-title">Dating / Matching Apps</h3>
          <p class="why-drift-body">The purpose is finding people itself. Filtered by profiles, conversations are goal-driven. Zero serendipity from travel.</p>
        </div>
        <div class="why-drift-card fade-up">
          <div class="why-drift-icon">&#x2715;</div>
          <h3 class="why-drift-title">Travel SNS / Forums</h3>
          <p class="why-drift-body">Focused on sharing information. No mechanism to leverage "being in the same place at the same time." Encounters are left to offline chance.</p>
        </div>
        <div class="why-drift-card why-drift-card--accent fade-up">
          <div class="why-drift-icon">&#x2713;</div>
          <h3 class="why-drift-title">Drift</h3>
          <p class="why-drift-body">Connects people naturally through shared travel — same place, same time. The only app that measures and accumulates the "meaning" of encounters, not just their volume.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Target Users -->
  <section class="section section--dark">
    <div class="section-inner">
      <div class="section-label-line">
        <span class="section-label">Who It's For</span>
      </div>
      <h2 class="drift-concept-heading fade-up" style="margin-bottom:2.5rem;">
        The first people Drift reaches.
      </h2>
      <div class="target-grid">
        <div class="target-card fade-up">
          <div class="target-emoji">&#x1F30F;</div>
          <h3 class="target-title">Solo Travelers (20s–30s)</h3>
          <p class="target-body">They value real encounters on the road but lack a way to find them. They hope for serendipity but don't want to "swipe" for it.</p>
        </div>
        <div class="target-card fade-up">
          <div class="target-emoji">&#x1F3D5;</div>
          <h3 class="target-title">Remote Workers & Long-Stayers</h3>
          <p class="target-body">Staying 1–3 months, wanting to connect with local communities. Looking for relationships beyond co-working spaces.</p>
        </div>
        <div class="target-card fade-up">
          <div class="target-emoji">&#x1F91D;</div>
          <h3 class="target-title">Group Trip Organizers</h3>
          <p class="target-body">Travel circles, social groups wanting deeper bonds between members. Drift structures the experience and increases return rates.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Roadmap -->
  <section class="section section--darker">
    <div class="section-inner">
      <div class="section-label-line">
        <span class="section-label">Roadmap</span>
      </div>
      <h2 class="drift-concept-heading fade-up" style="margin-bottom:2.5rem;">
        It starts here.
      </h2>
      <div class="roadmap">
        <div class="roadmap-item roadmap-item--active fade-up">
          <div class="roadmap-dot"></div>
          <div class="roadmap-content">
            <div class="roadmap-date">2026 Q1</div>
            <h3 class="roadmap-title">Founded · Product Design</h3>
            <p class="roadmap-body">Company established. Core concept design and MVP spec finalized.</p>
          </div>
        </div>
        <div class="roadmap-item fade-up">
          <div class="roadmap-dot"></div>
          <div class="roadmap-content">
            <div class="roadmap-date">2026 Q2</div>
            <h3 class="roadmap-title">Public Beta</h3>
            <p class="roadmap-body">Open beta launch. Validated in Southeast Asia backpacker hubs — Bali, Bangkok.</p>
          </div>
        </div>
        <div class="roadmap-item fade-up">
          <div class="roadmap-dot"></div>
          <div class="roadmap-content">
            <div class="roadmap-date">2026 Q3</div>
            <h3 class="roadmap-title">Global Launch</h3>
            <p class="roadmap-body">App Store / Google Play release. Global expansion starting with English-speaking markets and Southeast Asia. AI Concierge integrated.</p>
          </div>
        </div>
        <div class="roadmap-item fade-up">
          <div class="roadmap-dot"></div>
          <div class="roadmap-content">
            <div class="roadmap-date">2026 Q4</div>
            <h3 class="roadmap-title">Drift for Business</h3>
            <p class="roadmap-body">B2B plans for travel agencies, hostels, and tourism boards. Leverage encounter data to optimize guest acquisition and tourism strategy.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section section--dark drift-cta-section">
    <div class="section-inner" style="text-align:center;">
      <h2 class="drift-cta-heading fade-up">Let the current carry you<br />to someone worth meeting.</h2>
      <p class="section-body fade-up" style="margin:1.5rem auto 2.5rem;text-align:center;">
        Drift is currently in development. Stay tuned for updates.
      </p>
      <a href="mailto:cybertrip.inc@gmail.com" class="btn-pill btn-pill--accent magnetic-btn fade-up">
        <span class="magnetic-btn-text">Contact Us <span class="arrow">&rarr;</span></span>
      </a>
    </div>
  </section>

  <!-- Sticky CTA -->
  <div class="sticky-cta" id="stickyCta">
    <span class="sticky-cta-text">Drift is in development</span>
    <a href="mailto:cybertrip.inc@gmail.com" class="sticky-cta-btn">Contact Us <span class="arrow">&rarr;</span></a>
  </div>

  <Footer lang={lang} />
</Base>

<script>
  const stickyCta = document.getElementById('stickyCta');
  const hero = document.querySelector('.drift-hero');
  const footer = document.querySelector('footer');
  if (stickyCta && hero && footer) {
    const observer = new IntersectionObserver(([entry]) => {
      stickyCta.classList.toggle('sticky-cta--visible', !entry.isIntersecting);
    }, { threshold: 0 });
    observer.observe(hero);
    const footerObs = new IntersectionObserver(([entry]) => {
      stickyCta.classList.toggle('sticky-cta--hidden', entry.isIntersecting);
    }, { threshold: 0 });
    footerObs.observe(footer);
  }
</script>
