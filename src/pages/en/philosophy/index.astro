---
import Base from '../../../layouts/Base.astro';
import Header from '../../../components/Header.astro';
import AnnounceBanner from '../../../components/AnnounceBanner.astro';
import Philosophy from '../../../components/Philosophy.astro';
import ImageRow from '../../../components/ImageRow.astro';
import Concept from '../../../components/Concept.astro';
import VisionMission from '../../../components/VisionMission.astro';
import Footer from '../../../components/Footer.astro';

const lang = 'en';
---

<Base
  title="Philosophy — CyberTrip"
  description="Life happens beyond the screen. CyberTrip's philosophy on maximizing real experiences, encounters, and personal change through technology."
  lang={lang}
  page="philosophy"
>
  <AnnounceBanner lang={lang} />
  <Header lang={lang} page="philosophy" />
  <div class="page-hero page-hero--philosophy">
    <div class="page-hero-inner">
      <p class="page-hero-label">Philosophy</p>
      <h1 class="page-hero-title">Life happens<br />beyond the screen.</h1>
    </div>
  </div>
  <Philosophy lang={lang} />
  <ImageRow lang={lang} />
  <Concept lang={lang} />
  <VisionMission lang={lang} />
  <Footer lang={lang} />
</Base>
