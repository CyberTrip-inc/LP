---
import Base from '../../layouts/Base.astro';
import Header from '../../components/Header.astro';
import AnnounceBanner from '../../components/AnnounceBanner.astro';
import Hero from '../../components/Hero.astro';
import Closing from '../../components/Closing.astro';
import Footer from '../../components/Footer.astro';

const lang = 'en';
const base = '/en';
---

<Base
  title="CyberTrip — We move people from screens to real places."
  description="Maximizing the value of physical experience through technology. Drift: the only travel app where relationships accumulate trip by trip. CyberTrip, Inc."
  lang={lang}
>
  <AnnounceBanner lang={lang} />
  <Header lang={lang} />
  <Hero lang={lang} />

  <section class="section section--dark home-cards-section">
    <div class="section-inner">
      <div class="home-cards">
        <a href={`${base}/philosophy/`} class="home-card home-card--philosophy">
          <span class="home-card-label">Philosophy</span>
          <h3 class="home-card-title">We are already<br />"too connected."</h3>
          <p class="home-card-body">Maximizing the value of physical experience through technology. Our philosophy for bringing people back to reality.</p>
          <span class="home-card-arrow">&rarr;</span>
        </a>
        <a href={`${base}/drift/`} class="home-card home-card--drift">
          <span class="home-card-label">Product</span>
          <h3 class="home-card-title">DRIFT</h3>
          <p class="home-card-body">The only travel app where relationships accumulate trip by trip. Aiming for #1 in encounter success rate.</p>
          <span class="home-card-arrow">&rarr;</span>
        </a>
        <a href={`${base}/company/`} class="home-card home-card--company">
          <span class="home-card-label">Company</span>
          <h3 class="home-card-title">Company Profile</h3>
          <p class="home-card-body">A company using technology (Cyber) to design trips (Trip) that bring people back to the real world.</p>
          <span class="home-card-arrow">&rarr;</span>
        </a>
      </div>
    </div>
  </section>

  <!-- Numbers -->
  <section class="section section--darker">
    <div class="section-inner">
      <div class="section-label-line">
        <span class="section-label">Why Now</span>
      </div>
      <div class="home-stats">
        <div class="home-stat fade-up">
          <div class="home-stat-number">$11.7<span class="home-stat-unit">T</span></div>
          <div class="home-stat-label">Global Travel & Tourism Market</div>
        </div>
        <div class="home-stat fade-up">
          <div class="home-stat-number">73<span class="home-stat-unit">%</span></div>
          <div class="home-stat-label">Of travelers say encounters define trip satisfaction</div>
        </div>
        <div class="home-stat fade-up">
          <div class="home-stat-number">0</div>
          <div class="home-stat-label">Apps that measure the quality<br />of travel encounters — until now</div>
        </div>
      </div>
    </div>
  </section>

  <!-- Waitlist CTA -->
  <section class="section section--dark">
    <div class="section-inner" style="text-align:center;">
      <h2 class="drift-cta-heading fade-up">Change how you meet<br />on the road.</h2>
      <p class="section-body fade-up" style="margin:1.5rem auto 2rem;text-align:center;">
        Join the Drift waitlist for early access.
      </p>
      <form class="waitlist-form fade-up" action="mailto:hello@cybertrip.co.jp" method="get" enctype="text/plain">
        <input type="email" class="waitlist-input" placeholder="Enter your email" required />
        <button type="submit" class="waitlist-btn">
          Join Waitlist <span class="arrow">&rarr;</span>
        </button>
      </form>
      <p class="waitlist-note fade-up">No spam. Release updates only.</p>
    </div>
  </section>

  <Closing lang={lang} />
  <Footer lang={lang} />
</Base>
