---
import Base from '../../layouts/Base.astro';
import Header from '../../components/Header.astro';
import AnnounceBanner from '../../components/AnnounceBanner.astro';
import Hero from '../../components/Hero.astro';
import Closing from '../../components/Closing.astro';
import Footer from '../../components/Footer.astro';

const lang = 'en';
const base = '/en';
---

<Base
  title="CyberTrip — We move people from screens to real places."
  description="Maximizing the value of physical experience through technology. Drift: the only travel app where relationships accumulate trip by trip. CyberTrip, Inc."
  lang={lang}
>
  <AnnounceBanner lang={lang} />
  <Header lang={lang} />
  <Hero lang={lang} />

  <section class="section section--dark home-cards-section">
    <div class="section-inner">
      <div class="home-cards">
        <a href={`${base}/philosophy/`} class="home-card home-card--philosophy card-glow-border">
          <span class="home-card-label">Philosophy</span>
          <h3 class="home-card-title">We are already<br />"too connected."</h3>
          <p class="home-card-body">Maximizing the value of physical experience through technology. Our philosophy for bringing people back to reality.</p>
          <span class="home-card-arrow">&rarr;</span>
        </a>
        <a href={`${base}/drift/`} class="home-card home-card--drift card-glow-border">
          <span class="home-card-label">Product</span>
          <h3 class="home-card-title text-shimmer">DRIFT</h3>
          <p class="home-card-body">The only travel app where relationships accumulate trip by trip. Aiming for #1 in encounter success rate.</p>
          <span class="home-card-arrow">&rarr;</span>
        </a>
        <a href={`${base}/calcal/`} class="home-card home-card--calcal card-glow-border">
          <span class="home-card-label">Product</span>
          <h3 class="home-card-title text-shimmer">CALCAL</h3>
          <p class="home-card-body">An AI fitness and nutrition app that fuses meals, training, and body progress into the shortest path to your ideal body.</p>
          <span class="home-card-arrow">&rarr;</span>
        </a>
        <a href={`${base}/company/`} class="home-card home-card--company card-glow-border">
          <span class="home-card-label">Company</span>
          <h3 class="home-card-title">Company Profile</h3>
          <p class="home-card-body">A company using technology (Cyber) to design trips (Trip) that bring people back to the real world.</p>
          <span class="home-card-arrow">&rarr;</span>
        </a>
      </div>
    </div>
  </section>

  <!-- Numbers -->
  <section class="section section--darker">
    <div class="section-inner">
      <div class="section-label-line">
        <span class="section-label">Why Now</span>
      </div>
      <div class="home-stats">
        <div class="home-stat fade-up">
          <div class="home-stat-number counter-glow">$<span class="counter" data-target="11.7" data-decimals="1">0</span><span class="home-stat-unit">T</span></div>
          <div class="home-stat-label">Global Travel & Tourism Market</div>
        </div>
        <div class="home-stat fade-up">
          <div class="home-stat-number counter-glow"><span class="counter" data-target="73">0</span><span class="home-stat-unit">%</span></div>
          <div class="home-stat-label">Of travelers say encounters define trip satisfaction<span class="stat-source">*</span></div>
        </div>
        <div class="home-stat fade-up">
          <div class="home-stat-number counter-glow"><span class="counter" data-target="0">0</span></div>
          <div class="home-stat-label">Apps that measure the quality<br />of travel encounters — until now</div>
        </div>
      </div>
      <p class="stat-footnote fade-up">* Source: Booking.com "Traveler Confidence Index 2024" — Survey on impact of social interactions on overall trip satisfaction</p>
    </div>
  </section>

  <Closing lang={lang} />
  <Footer lang={lang} />
</Base>
