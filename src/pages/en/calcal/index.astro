---
import Base from '../../../layouts/Base.astro';
import Header from '../../../components/Header.astro';
import AnnounceBanner from '../../../components/AnnounceBanner.astro';
import CalCal from '../../../components/CalCal.astro';
import Footer from '../../../components/Footer.astro';

const lang = 'en';
---

<Base
  title="CalCal — CyberTrip"
  description="An AI fitness and nutrition app that fuses meals, training, and body progress into the shortest path to your ideal body."
  lang={lang}
  page="calcal"
>
  <AnnounceBanner lang={lang} />
  <Header lang={lang} page="calcal" />

  <!-- CalCal Hero -->
  <section class="drift-hero">
    <div class="drift-hero-aurora">
      <div class="drift-hero-blob drift-hero-blob--1"></div>
      <div class="drift-hero-blob drift-hero-blob--2"></div>
    </div>
    <div class="drift-hero-inner">
      <p class="page-hero-label">Product</p>
      <h1 class="drift-hero-name text-shimmer">CALCAL</h1>
      <p class="drift-hero-tagline">Your ideal body,<br />on the shortest path.</p>
      <p class="drift-hero-desc">
        Meals, training, and body change — analyzed together by AI.<br />
        Not willpower. Not guesswork.<br />
        Technology that draws the shortest route to the body you want.
      </p>
    </div>
  </section>

  <!-- Concept -->
  <section class="section section--dark">
    <div class="section-inner">
      <div class="section-label-line">
        <span class="section-label">Concept</span>
      </div>
      <div class="drift-concept">
        <div class="drift-concept-main">
          <h2 class="drift-concept-heading fade-up">
            Health apps that just<br />keep you logging are not enough.
          </h2>
          <p class="drift-concept-body fade-up">
            Most fitness and nutrition apps make logging the goal. Data piles up — your body doesn't change. CalCal points the other way: <strong>get to your ideal body on the shortest path.</strong>
          </p>
          <p class="drift-concept-body fade-up">
            Meals optimize intake. Training optimizes output. Weight and progress photos verify the result. AI fuses all three and tells you what to do next, every day.<br />
            One question drives every recommendation: <strong>does this bring you closer to your ideal body, faster?</strong>
          </p>
        </div>
        <div class="drift-concept-side">
          <div class="drift-concept-quote fade-up">
            <span class="drift-concept-quote-mark">"</span>
            <p>Not an app to keep using.<br />An app that changes you fastest.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- How it works -->
  <section class="section section--darker">
    <div class="section-inner">
      <div class="section-label-line">
        <span class="section-label">How It Works</span>
      </div>
      <div class="drift-flow">
        <div class="drift-flow-step fade-up">
          <div class="drift-flow-number drift-flow-number--accent">01</div>
          <h3 class="drift-flow-title">Snap your meal</h3>
          <p class="drift-flow-body">Photograph your plate. AI estimates portion size against your hand, phone, or chopsticks — even infers hidden oils and sugars.</p>
        </div>
        <div class="drift-flow-step fade-up">
          <div class="drift-flow-number drift-flow-number--teal">02</div>
          <h3 class="drift-flow-title">Log training & body</h3>
          <p class="drift-flow-body">Record sets, reps, and weight. Track body weight and body fat. Designed to take three seconds, not three minutes.</p>
        </div>
        <div class="drift-flow-step fade-up">
          <div class="drift-flow-number drift-flow-number--blue">03</div>
          <h3 class="drift-flow-title">AI fuses it all</h3>
          <p class="drift-flow-body">Meals, training, and body change — analyzed together. Every morning and evening, CalCal tells you what today's choices mean for your goal.</p>
        </div>
        <div class="drift-flow-step fade-up">
          <div class="drift-flow-number drift-flow-number--accent">04</div>
          <h3 class="drift-flow-title">Reach your goal, faster</h3>
          <p class="drift-flow-body">Numbers and side-by-side photos prove the change. The distance to your ideal body shrinks every day.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Features (Bento Grid) -->
  <CalCal lang={lang} />

  <!-- Why CalCal -->
  <section class="section section--darker">
    <div class="section-inner">
      <div class="section-label-line">
        <span class="section-label">Why CalCal</span>
      </div>
      <h2 class="drift-concept-heading fade-up" style="margin-bottom:2.5rem;">
        Why existing apps fail to deliver.
      </h2>
      <div class="why-drift-grid">
        <div class="why-drift-card fade-up">
          <div class="why-drift-icon">&#x2715;</div>
          <h3 class="why-drift-title">Nutrition trackers</h3>
          <p class="why-drift-body">Manual entry is heavy. People drop off. And even if they don't, meal data lives separately from training and body change.</p>
        </div>
        <div class="why-drift-card fade-up">
          <div class="why-drift-icon">&#x2715;</div>
          <h3 class="why-drift-title">Fitness apps</h3>
          <p class="why-drift-body">Workouts only. Diet and body composition are someone else's problem. No way to know what actually moved the needle.</p>
        </div>
        <div class="why-drift-card why-drift-card--accent why-drift-card--drift fade-up">
          <div class="why-drift-icon">&#x2713;</div>
          <h3 class="why-drift-title">CalCal</h3>
          <p class="why-drift-body">Meals, training, and body change fused by AI into a single shortest path. Every recommendation is optimized for change, not for engagement.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Target Users -->
  <section class="section section--dark">
    <div class="section-inner">
      <div class="section-label-line">
        <span class="section-label">Who It's For</span>
      </div>
      <h2 class="drift-concept-heading fade-up" style="margin-bottom:2.5rem;">
        The first people CalCal reaches.
      </h2>
      <div class="target-grid">
        <div class="target-card fade-up">
          <div class="target-emoji">&#x1F525;</div>
          <h3 class="target-title">DIY dieters who plateaued</h3>
          <p class="target-body">Already restricting meals and training hard, but the scale won't move. They can't see what's missing — CalCal can.</p>
        </div>
        <div class="target-card fade-up">
          <div class="target-emoji">&#x1F4AA;</div>
          <h3 class="target-title">Post-PT self-managers</h3>
          <p class="target-body">Got results from a personal trainer, but unsure how to keep going alone. CalCal hands them the next step, every day.</p>
        </div>
        <div class="target-card fade-up">
          <div class="target-emoji">&#x1F3AF;</div>
          <h3 class="target-title">Time-bound professionals</h3>
          <p class="target-body">Time is finite. They don't want grit — they want the shortest, technology-led path to the body they want.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Roadmap -->
  <section class="section section--darker">
    <div class="section-inner">
      <div class="section-label-line">
        <span class="section-label">Roadmap</span>
      </div>
      <h2 class="drift-concept-heading fade-up" style="margin-bottom:2.5rem;">
        It starts here.
      </h2>
      <div class="roadmap">
        <div class="roadmap-item roadmap-item--active fade-up">
          <div class="roadmap-dot"></div>
          <div class="roadmap-content">
            <div class="roadmap-date">2026 Q1</div>
            <h3 class="roadmap-title">Concept · MVP Build</h3>
            <p class="roadmap-body">Core features narrowed by one rule: does this bring users closer to their ideal body, faster? AI meal analysis and the integrated analysis engine in development.</p>
          </div>
        </div>
        <div class="roadmap-item fade-up">
          <div class="roadmap-dot"></div>
          <div class="roadmap-content">
            <div class="roadmap-date">2026 Q2</div>
            <h3 class="roadmap-title">Closed Beta</h3>
            <p class="roadmap-body">10–30 user pilot. Measure AI accuracy, retention, and body composition outcomes. Sharpen the definition of "shortest path" against real data.</p>
          </div>
        </div>
        <div class="roadmap-item fade-up">
          <div class="roadmap-dot"></div>
          <div class="roadmap-content">
            <div class="roadmap-date">2026 Q3</div>
            <h3 class="roadmap-title">Public Beta · iOS Launch</h3>
            <p class="roadmap-body">App Store release in Japan, starting with the fitness-conscious. Pre-meal AI checks and AI photo comparison shipped.</p>
          </div>
        </div>
        <div class="roadmap-item fade-up">
          <div class="roadmap-dot"></div>
          <div class="roadmap-content">
            <div class="roadmap-date">2026 Q4</div>
            <h3 class="roadmap-title">AI Coaching</h3>
            <p class="roadmap-body">Personalized recommendations based on each user's history. AI prescribes training, nutrition, and recovery as a single integrated plan.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section section--dark drift-cta-section">
    <div class="section-inner" style="text-align:center;">
      <h2 class="drift-cta-heading fade-up">Get to your ideal body,<br />the shortest way.</h2>
      <p class="section-body fade-up" style="margin:1.5rem auto 2.5rem;text-align:center;">
        CalCal is currently in development. Stay tuned for updates.
      </p>
      <a href="mailto:cybertrip.inc@gmail.com" class="btn-pill btn-pill--accent magnetic-btn fade-up">
        <span class="magnetic-btn-text">Contact Us <span class="arrow">&rarr;</span></span>
      </a>
    </div>
  </section>

  <!-- Sticky CTA -->
  <div class="sticky-cta" id="stickyCta">
    <span class="sticky-cta-text">CalCal is in development</span>
    <a href="mailto:cybertrip.inc@gmail.com" class="sticky-cta-btn">Contact Us <span class="arrow">&rarr;</span></a>
  </div>

  <Footer lang={lang} />
</Base>

<script>
  const stickyCta = document.getElementById('stickyCta');
  const hero = document.querySelector('.drift-hero');
  const footer = document.querySelector('footer');
  if (stickyCta && hero && footer) {
    const observer = new IntersectionObserver(([entry]) => {
      stickyCta.classList.toggle('sticky-cta--visible', !entry.isIntersecting);
    }, { threshold: 0 });
    observer.observe(hero);
    const footerObs = new IntersectionObserver(([entry]) => {
      stickyCta.classList.toggle('sticky-cta--hidden', entry.isIntersecting);
    }, { threshold: 0 });
    footerObs.observe(footer);
  }
</script>
