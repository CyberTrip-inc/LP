---
import Base from '../../../layouts/Base.astro';
import Header from '../../../components/Header.astro';
import AnnounceBanner from '../../../components/AnnounceBanner.astro';
import Footer from '../../../components/Footer.astro';

const lang = 'ja';

const rows = [
  { key: '会社名', value: '株式会社CyberTrip' },
  { key: '代表取締役', value: '熊倉 一哉 / 上原 裕生' },
  { key: '資本金', value: '10万円' },
  { key: '事業内容', value: '旅行関連アプリケーションの企画・開発・運営' },
  { key: 'URL', value: 'cybertrip.co.jp' },
];

const values = [
  {
    label: 'Mission',
    en: 'We move people from screens to real places.',
    title: 'テクノロジーで、<br />人を現実世界へ連れ出す。',
    body: '世界中のテクノロジー企業が、人々の可処分時間を奪い合っている。CyberTripは、テクノロジーを「入口」ではなく「出口」として使う。',
    color: 'accent',
  },
  {
    label: 'Vision',
    en: 'A world where real experiences enrich real lives.',
    title: '画面の外で生まれる体験が、<br />人生を豊かにする世界。',
    body: 'デジタルが進化すればするほど、「現地にいること」の価値は相対的に上がっていく。',
    color: 'teal',
  },
];

const founders = [
  {
    name: '熊倉 一哉',
    nameEn: 'Kazuya Kumakura',
    role: 'Co-Founder / CEO',
    bio: 'アドテクノロジー企業でエンジニアを経験。旅先での偶然の出会いが人生を変えた経験から、「出会いの構造」を再設計するためにCyberTripを創業。プロダクト戦略・事業開発を統括。',
  },
  {
    name: '上原 裕生',
    nameEn: 'Yusei Uehara',
    role: 'Co-Founder / CTO',
    bio: 'アドテクノロジー企業でエンジニアを経験。旅先での偶然の出会いが人生を変えた経験から、「出会いの構造」を再設計するためにCyberTripを創業。開発全般を統括。',
  },
];
---

<Base
  title="会社概要 — CyberTrip"
  description="テクノロジーで人を現実世界へ連れ出す。株式会社CyberTripの会社情報。"
  lang={lang}
  page="company"
>
  <AnnounceBanner lang={lang} />
  <Header lang={lang} page="company" />

  <!-- Company Hero -->
  <section class="page-hero page-hero--company">
    <div class="page-hero-inner">
      <p class="page-hero-label">Company</p>
      <h1 class="page-hero-title">テクノロジーで、<br />人を現実世界へ連れ出す会社。</h1>
      <p class="page-hero-sub">
        体験が生まれ、記憶として蓄積され、再び価値として循環する。<br />
        その構造そのものを設計するために、CyberTripは生まれました。
      </p>
    </div>
  </section>

  <!-- Mission & Vision Cards -->
  <section class="section section--dark">
    <div class="section-inner">
      <div class="section-label-line">
        <span class="section-label">Vision / Mission</span>
      </div>
      <div class="company-mv-grid">
        {values.map((item) => (
          <div class={`company-mv-card company-mv-card--${item.color}`}>
            <div class="company-mv-label">{item.label}</div>
            <p class="company-mv-en">{item.en}</p>
            <h3 class="company-mv-title" set:html={item.title} />
            <p class="company-mv-body">{item.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Founders -->
  <section class="section section--darker">
    <div class="section-inner">
      <div class="section-label-line">
        <span class="section-label">Founders</span>
      </div>
      <div class="founders-grid">
        {founders.map((f) => (
          <div class="founder-card">
            <div class="founder-card-header">
              <div class="founder-avatar">{f.name.charAt(0)}</div>
              <div class="founder-info">
                <div class="founder-name">{f.name}</div>
                <div class="founder-name-en">{f.nameEn}</div>
                <div class="founder-role">{f.role}</div>
              </div>
            </div>
            <p class="founder-bio">{f.bio}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Company Profile Table -->
  <section class="section section--dark">
    <div class="section-inner">
      <div class="section-label-line">
        <span class="section-label">Company Profile</span>
      </div>
      <div class="company-table-wrap">
        {rows.map((row) => (
          <div class="company-row">
            <span class="company-key">{row.key}</span>
            <span class="company-value">{row.value}</span>
          </div>
        ))}
      </div>
      <p class="company-note fade-up">
        テクノロジー（Cyber）を使って、人を現実世界へ連れ出す旅（Trip）を設計する会社。体験が生まれ、記憶として蓄積され、再び価値として循環する構造そのものを設計するために設立。
      </p>
    </div>
  </section>

  <!-- Contact CTA -->
  <section class="section section--darker" style="padding-top:4rem;">
    <div class="section-inner" style="text-align:center;">
      <h2 class="drift-cta-heading fade-up">一緒に、未来を作りませんか。</h2>
      <p class="section-body fade-up" style="margin:1.5rem auto 2.5rem;text-align:center;">
        採用・パートナーシップ・取材に関するお問い合わせ
      </p>
      <a href="mailto:hello@cybertrip.co.jp" class="btn-pill btn-pill--accent magnetic-btn fade-up">
        <span class="magnetic-btn-text">お問い合わせ <span class="arrow">&rarr;</span></span>
      </a>
    </div>
  </section>

  <Footer lang={lang} />
</Base>
