---
import Base from '../../layouts/Base.astro';
import Header from '../../components/Header.astro';
import AnnounceBanner from '../../components/AnnounceBanner.astro';
import Hero from '../../components/Hero.astro';
import Closing from '../../components/Closing.astro';
import Footer from '../../components/Footer.astro';

const lang = 'ja';
const base = '/ja';
---

<Base
  title="CyberTrip — テクノロジーで、人を現実世界へ連れ出す。"
  description="テクノロジーで、物理体験の価値を最大化する。旅を単位に人間関係が蓄積される唯一の旅行アプリ Drift を開発する株式会社CyberTrip。"
  lang={lang}
>
  <AnnounceBanner lang={lang} />
  <Header lang={lang} />
  <Hero lang={lang} />

  <section class="section section--dark home-cards-section">
    <div class="section-inner">
      <div class="home-cards">
        <a href={`${base}/philosophy/`} class="home-card home-card--philosophy">
          <span class="home-card-label">Philosophy</span>
          <h3 class="home-card-title">私たちは、すでに<br />"繋がりすぎている"。</h3>
          <p class="home-card-body">テクノロジーで、物理体験の価値を最大化する。人を現実へ連れ出すための思想。</p>
          <span class="home-card-arrow">&rarr;</span>
        </a>
        <a href={`${base}/drift/`} class="home-card home-card--drift">
          <span class="home-card-label">Product</span>
          <h3 class="home-card-title">DRIFT</h3>
          <p class="home-card-body">旅を単位に、人間関係が蓄積される唯一の旅行アプリ。出会いの「成功率」で世界一を目指す。</p>
          <span class="home-card-arrow">&rarr;</span>
        </a>
        <a href={`${base}/company/`} class="home-card home-card--company">
          <span class="home-card-label">Company</span>
          <h3 class="home-card-title">会社概要</h3>
          <p class="home-card-body">テクノロジー(Cyber)を使って、人を現実世界へ連れ出す旅(Trip)を設計する会社。</p>
          <span class="home-card-arrow">&rarr;</span>
        </a>
      </div>
    </div>
  </section>

  <!-- Numbers -->
  <section class="section section--darker">
    <div class="section-inner">
      <div class="section-label-line">
        <span class="section-label">Why Now</span>
      </div>
      <div class="home-stats">
        <div class="home-stat fade-up">
          <div class="home-stat-number">11.7<span class="home-stat-unit">兆USD</span></div>
          <div class="home-stat-label">世界の旅行・観光市場規模</div>
        </div>
        <div class="home-stat fade-up">
          <div class="home-stat-number">73<span class="home-stat-unit">%</span></div>
          <div class="home-stat-label">「旅先での出会いが旅の満足度を決める」と回答した旅行者の割合</div>
        </div>
        <div class="home-stat fade-up">
          <div class="home-stat-number">0<span class="home-stat-unit">個</span></div>
          <div class="home-stat-label">「出会いの質」を測定する<br />旅行アプリは、まだない</div>
        </div>
      </div>
    </div>
  </section>

  <!-- Waitlist CTA -->
  <section class="section section--dark">
    <div class="section-inner" style="text-align:center;">
      <h2 class="drift-cta-heading fade-up">旅の出会いを、変えよう。</h2>
      <p class="section-body fade-up" style="margin:1.5rem auto 2rem;text-align:center;">
        Driftのウェイトリストに登録して、最新情報を受け取る。
      </p>
      <form class="waitlist-form fade-up" action="mailto:hello@cybertrip.co.jp" method="get" enctype="text/plain">
        <input type="email" class="waitlist-input" placeholder="メールアドレスを入力" required />
        <button type="submit" class="waitlist-btn">
          ウェイトリスト登録 <span class="arrow">&rarr;</span>
        </button>
      </form>
      <p class="waitlist-note fade-up">スパムは送りません。リリース情報のみお届けします。</p>
    </div>
  </section>

  <Closing lang={lang} />
  <Footer lang={lang} />
</Base>
