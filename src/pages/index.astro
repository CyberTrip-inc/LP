<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>CyberTrip</title>
  <link rel="alternate" hreflang="ja" href="https://cybertrip.co.jp/ja/">
  <link rel="alternate" hreflang="en" href="https://cybertrip.co.jp/en/">
</head>
<body>
  <main class="lang-select-page">
    <div class="lang-select-aurora">
      <div class="hero-blob hero-blob--1"></div>
