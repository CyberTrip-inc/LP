---
// Language selector landing page — cinematic splash
---

<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>CyberTrip</title>
  <meta name="description" content="We move people from screens to real places.">
  <link rel="alternate" hreflang="ja" href="https://cybertrip.co.jp/ja/">
  <link rel="alternate" hreflang="en" href="https://cybertrip.co.jp/en/">
  <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png">
  <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@500;600;700&family=Inter:wght@300;400;500&display=swap" rel="stylesheet">
</head>
<body>
  <main class="splash">
    <!-- Animated background -->
    <div class="splash-bg">
      <div class="splash-orb splash-orb--1"></div>
      <div class="splash-orb splash-orb--2"></div>
      <div class="splash-orb splash-orb--3"></div>
      <div class="splash-grid"></div>
    </div>

    <!-- Particle ring around logo -->
    <canvas id="particleCanvas" class="splash-particles"></canvas>

    <!-- Content -->
    <div class="splash-content">
      <div class="splash-logo-wrap" id="logoWrap">
        <img src="/icon.png" alt="CyberTrip" class="splash-icon" width="80" height="80" />
      </div>

      <h1 class="splash-title" id="splashTitle">CyberTrip</h1>

      <p class="splash-tagline" id="splashTagline">We move people from screens to real places.</p>

      <div class="splash-divider" id="splashDivider"></div>

      <div class="splash-links" id="splashLinks">
        <a href="/ja/" class="splash-btn">
          <span class="splash-btn-text">日本語</span>
          <span class="splash-btn-arrow">&rarr;</span>
        </a>
        <a href="/en/" class="splash-btn">
          <span class="splash-btn-text">English</span>
          <span class="splash-btn-arrow">&rarr;</span>
        </a>
      </div>
    </div>
  </main>

  <style>
    @import '../styles/global.css';

    * { margin: 0; padding: 0; box-sizing: border-box; }

    body {
      background: #060a14;
      overflow: hidden;
      -webkit-font-smoothing: antialiased;
    }

    /* ============================================
       SPLASH BACKGROUND
       ============================================ */
    .splash {
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      position: relative;
      overflow: hidden;
    }

    .splash-bg {
      position: absolute;
      inset: 0;
      z-index: 0;
    }

    .splash-orb {
      position: absolute;
      border-radius: 50%;
      filter: blur(100px);
      opacity: 0;
      animation: orbFadeIn 3s ease-out forwards;
    }

    .splash-orb--1 {
      width: 600px;
      height: 600px;
      background: radial-gradient(circle, rgba(74, 142, 237, 0.15), transparent 70%);
      top: -10%;
      left: -10%;
      animation-delay: 0.5s;
    }

    .splash-orb--2 {
      width: 500px;
      height: 500px;
      background: radial-gradient(circle, rgba(61, 165, 217, 0.12), transparent 70%);
      bottom: -15%;
      right: -5%;
      animation-delay: 1s;
    }

    .splash-orb--3 {
      width: 400px;
      height: 400px;
      background: radial-gradient(circle, rgba(30, 58, 123, 0.18), transparent 70%);
      top: 50%;
      left: 50%;
      transform: translate(-50%, -50%);
      animation-delay: 0.3s;
    }

    @keyframes orbFadeIn {
      0%   { opacity: 0; transform: scale(0.5); }
      100% { opacity: 1; transform: scale(1); }
    }

    .splash-orb--3 {
      animation-name: orbFadeInCenter;
    }

    @keyframes orbFadeInCenter {
      0%   { opacity: 0; transform: translate(-50%, -50%) scale(0.5); }
      100% { opacity: 1; transform: translate(-50%, -50%) scale(1); }
    }

    /* Subtle grid overlay */
    .splash-grid {
      position: absolute;
      inset: 0;
      background-image:
        linear-gradient(rgba(255,255,255,0.015) 1px, transparent 1px),
        linear-gradient(90deg, rgba(255,255,255,0.015) 1px, transparent 1px);
      background-size: 80px 80px;
      mask-image: radial-gradient(ellipse 60% 60% at 50% 50%, black 20%, transparent 70%);
      -webkit-mask-image: radial-gradient(ellipse 60% 60% at 50% 50%, black 20%, transparent 70%);
    }

    /* Particle canvas */
    .splash-particles {
      position: absolute;
      inset: 0;
      z-index: 1;
      pointer-events: none;
      clip-path: inset(0 0 45% 0);
    }

    /* Noise overlay */
    .splash::after {
      content: '';
      position: absolute;
      inset: 0;
      z-index: 2;
      pointer-events: none;
      opacity: 0.03;
      background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)'/%3E%3C/svg%3E");
      background-repeat: repeat;
      background-size: 256px 256px;
    }

    /* ============================================
       CONTENT
       ============================================ */
    .splash-content {
      position: relative;
      z-index: 10;
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 0;
    }

    /* Logo */
    .splash-logo-wrap {
      opacity: 0;
      transform: scale(0.6) translateY(20px);
      animation: logoReveal 1.2s cubic-bezier(0.16, 1, 0.3, 1) 0.3s forwards;
    }

    @keyframes logoReveal {
      0%   { opacity: 0; transform: scale(0.6) translateY(20px); filter: blur(10px); }
      100% { opacity: 1; transform: scale(1) translateY(0); filter: blur(0); }
    }

    .splash-icon {
      width: 80px;
      height: 80px;
      filter: drop-shadow(0 0 30px rgba(74, 142, 237, 0.3));
    }

    /* Title */
    .splash-title {
      font-family: 'Space Grotesk', sans-serif;
      font-size: clamp(2.5rem, 6vw, 4.5rem);
      font-weight: 700;
      letter-spacing: -0.02em;
      text-align: center;
      margin-top: 2rem;
      opacity: 0;
      animation: titleReveal 1.4s cubic-bezier(0.16, 1, 0.3, 1) 0.7s forwards;
      background: linear-gradient(135deg, #ffffff 0%, #ffffff 50%, #4a8eed 100%);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }

    @keyframes titleReveal {
      0%   { opacity: 0; transform: translateY(30px); filter: blur(12px); letter-spacing: 0.3em; }
      100% { opacity: 1; transform: translateY(0); filter: blur(0); letter-spacing: -0.02em; }
    }

    /* Tagline */
    .splash-tagline {
      font-family: 'Inter', sans-serif;
      font-size: clamp(0.85rem, 1.5vw, 1rem);
      font-weight: 300;
      color: rgba(255, 255, 255, 0.35);
      letter-spacing: 0.15em;
      text-align: center;
      margin-top: 1rem;
      opacity: 0;
      animation: fadeUp 1s cubic-bezier(0.16, 1, 0.3, 1) 1.2s forwards;
    }

    /* Divider beam */
    .splash-divider {
      width: 60px;
      height: 1px;
      background: linear-gradient(90deg, transparent, rgba(74, 142, 237, 0.5), transparent);
      margin-top: 2.5rem;
      opacity: 0;
      animation: dividerReveal 1.2s ease-out 1.5s forwards;
    }

    @keyframes dividerReveal {
      0%   { opacity: 0; width: 0; }
      100% { opacity: 1; width: 60px; }
    }

    /* Links */
    .splash-links {
      display: flex;
      gap: 1rem;
      margin-top: 2.5rem;
      opacity: 0;
      animation: fadeUp 1s cubic-bezier(0.16, 1, 0.3, 1) 1.8s forwards;
    }

    @keyframes fadeUp {
      0%   { opacity: 0; transform: translateY(15px); }
      100% { opacity: 1; transform: translateY(0); }
    }

    .splash-btn {
      font-family: 'Inter', sans-serif;
      font-size: 0.9rem;
      font-weight: 500;
      color: rgba(255, 255, 255, 0.6);
      text-decoration: none;
      padding: 0.9rem 2.2rem;
      border: 1px solid rgba(255, 255, 255, 0.08);
      border-radius: 999px;
      background: rgba(255, 255, 255, 0.03);
      backdrop-filter: blur(20px);
      -webkit-backdrop-filter: blur(20px);
      transition: all 0.5s cubic-bezier(0.16, 1, 0.3, 1);
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 0.5rem;
      position: relative;
      overflow: hidden;
      min-width: 160px;
    }

    .splash-btn::before {
      content: '';
      position: absolute;
      inset: 0;
      border-radius: inherit;
      background: radial-gradient(circle at var(--mx, 50%) var(--my, 50%), rgba(74, 142, 237, 0.12), transparent 60%);
      opacity: 0;
      transition: opacity 0.4s;
    }

    .splash-btn:hover::before {
      opacity: 1;
    }

    .splash-btn:hover {
      color: #ffffff;
      border-color: rgba(74, 142, 237, 0.4);
      background: rgba(74, 142, 237, 0.06);
      transform: translateY(-2px);
      box-shadow: 0 8px 32px -8px rgba(74, 142, 237, 0.2);
    }

    .splash-btn-text {
      position: relative;
      z-index: 1;
    }

    .splash-btn-arrow {
      position: absolute;
      right: 1.2rem;
      z-index: 1;
      opacity: 0;
      transform: translateX(-4px);
      transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
      font-size: 0.85rem;
    }

    .splash-btn:hover .splash-btn-arrow {
      opacity: 0.7;
      transform: translateX(0);
    }

    /* ============================================
       RESPONSIVE
       ============================================ */
    @media (max-width: 480px) {
      .splash-links {
        flex-direction: column;
        gap: 0.75rem;
        width: 100%;
        padding: 0 2rem;
      }
      .splash-btn {
        justify-content: center;
        width: 100%;
      }
    }

    /* ============================================
       REDUCED MOTION
       ============================================ */
    @media (prefers-reduced-motion: reduce) {
      .splash-logo-wrap,
      .splash-title,
      .splash-tagline,
      .splash-divider,
      .splash-links,
      .splash-orb {
        animation: none !important;
        opacity: 1 !important;
        transform: none !important;
        filter: none !important;
      }
      .splash-particles { display: none; }
    }
  </style>

  <script is:inline>
    // Particle ring animation
    (function () {
      var canvas = document.getElementById('particleCanvas');
      if (!canvas) return;
      var ctx = canvas.getContext('2d');
      var w, h, cx, cy;
      var particles = [];
      var count = 60;

      function resize() {
        w = canvas.width = window.innerWidth;
        h = canvas.height = window.innerHeight;
        cx = w / 2;
        cy = h / 2;
      }

      function createParticles() {
        particles = [];
        for (var i = 0; i < count; i++) {
          var angle = (Math.PI * 2 / count) * i;
          var radius = Math.min(w, h) * 0.22;
          particles.push({
            angle: angle,
            radius: radius + (Math.random() - 0.5) * 40,
            size: Math.random() * 1.5 + 0.5,
            speed: (Math.random() - 0.5) * 0.003,
            opacity: Math.random() * 0.5 + 0.1,
            drift: Math.random() * 0.5
          });
        }
      }

      function draw() {
        ctx.clearRect(0, 0, w, h);

        for (var i = 0; i < particles.length; i++) {
          var p = particles[i];
          p.angle += p.speed;
          var x = cx + Math.cos(p.angle) * p.radius;
          var y = cy + Math.sin(p.angle) * (p.radius * 0.6);

          ctx.beginPath();
          ctx.arc(x, y, p.size, 0, Math.PI * 2);
          ctx.fillStyle = 'rgba(74, 142, 237, ' + p.opacity + ')';
          ctx.fill();
        }

        requestAnimationFrame(draw);
      }

      resize();
      createParticles();
      draw();
      window.addEventListener('resize', function () {
        resize();
        createParticles();
      });

      // Button ripple tracking
      document.querySelectorAll('.splash-btn').forEach(function (btn) {
        btn.addEventListener('mousemove', function (e) {
          var rect = btn.getBoundingClientRect();
          btn.style.setProperty('--mx', ((e.clientX - rect.left) / rect.width * 100) + '%');
          btn.style.setProperty('--my', ((e.clientY - rect.top) / rect.height * 100) + '%');
        });
      });
    })();
  </script>
</body>
</html>
