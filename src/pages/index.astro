---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import AnnounceBanner from '../components/AnnounceBanner.astro';
import Hero from '../components/Hero.astro';
import Closing from '../components/Closing.astro';
import Footer from '../components/Footer.astro';

const lang = 'ja';
const base = '';
---

<Base
  title="CyberTrip — テクノロジーで、人を現実世界へ連れ出す。"
  description="テクノロジーで、現実の体験の価値を最大化する株式会社CyberTrip。旅で人とつながる Drift と、AIで理想の身体への最短ルートを描く Forge を開発。"
  lang={lang}
>
  <AnnounceBanner lang={lang} />
  <Header lang={lang} />
  <Hero lang={lang} />

  <section class="section section--dark home-cards-section">
    <div class="section-inner">
      <div class="home-cards">
        <a href={`${base}/philosophy/`} class="home-card home-card--philosophy card-glow-border">
          <span class="home-card-label">Philosophy</span>
          <h3 class="home-card-title">人生は、<br />画面の外で動いている。</h3>
          <p class="home-card-body">出会い、身体の変化、記憶に残る体験——人生を動かすものは、すべて画面の外にある。テクノロジーを"出口"として設計する思想。</p>
          <span class="home-card-arrow">&rarr;</span>
        </a>
        <a href={`${base}/drift/`} class="home-card home-card--drift card-glow-border">
          <span class="home-card-label">Product</span>
          <h3 class="home-card-title text-shimmer">DRIFT</h3>
          <p class="home-card-body">旅を単位に、人間関係が蓄積される唯一の旅行アプリ。出会いの「成功率」で世界一を目指す。</p>
          <span class="home-card-arrow">&rarr;</span>
        </a>
        <a href={`${base}/forge/`} class="home-card home-card--forge card-glow-border">
          <span class="home-card-label">Product</span>
          <h3 class="home-card-title text-shimmer">FORGE</h3>
          <p class="home-card-body">食事 × 筋トレ × 体の変化をAIが統合分析。理想のカラダまでの最短ルートを描くフィットネス・栄養管理アプリ。</p>
          <span class="home-card-arrow">&rarr;</span>
        </a>
        <a href={`${base}/company/`} class="home-card home-card--company card-glow-border">
          <span class="home-card-label">Company</span>
          <h3 class="home-card-title">会社概要</h3>
          <p class="home-card-body">テクノロジー(Cyber)を使って、人を現実世界へ連れ出す旅(Trip)を設計する会社。</p>
          <span class="home-card-arrow">&rarr;</span>
        </a>
      </div>
    </div>
  </section>

  <!-- Numbers -->
  <section class="section section--darker">
    <div class="section-inner">
      <div class="section-label-line">
        <span class="section-label">Why Now</span>
      </div>
      <div class="home-stats">
        <div class="home-stat fade-up">
          <div class="home-stat-number counter-glow"><span class="counter" data-target="11.6" data-decimals="1">0</span><span class="home-stat-unit">兆USD</span></div>
          <div class="home-stat-label">世界の旅行・観光市場規模<span class="stat-source">*</span></div>
        </div>
        <div class="home-stat fade-up">
          <div class="home-stat-number counter-glow"><span class="counter" data-target="71">0</span><span class="home-stat-unit">%</span></div>
          <div class="home-stat-label">旅先で出会いを積極的に求めているソロトラベラーの割合<span class="stat-source">**</span></div>
        </div>
        <div class="home-stat fade-up">
          <div class="home-stat-number counter-glow"><span class="counter" data-target="0">0</span><span class="home-stat-unit">個</span></div>
          <div class="home-stat-label">「出会いの質」を測定する<br />旅行アプリは、まだない</div>
        </div>
      </div>
      <p class="stat-footnote fade-up">* 出典: WTTC「Economic Impact Report 2025」— 2025年 旅行・観光産業の世界GDP貢献額<br />** 出典: Hostelworld「State of Solo Travel Report 2025」— 世界のソロトラベラー3,334人を対象とした調査</p>
    </div>
  </section>

  <Closing lang={lang} />
  <Footer lang={lang} />
</Base>
